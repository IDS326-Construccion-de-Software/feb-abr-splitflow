rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil de usuario: solo el dueño puede leer/escribir su doc.
    match /users/{userId} {
      // Lectura: cualquier usuario autenticado puede leer perfiles básicos (para mostrar nombres en grupos/saldos).
      allow read: if request.auth != null;
      // Escritura/actualización: solo el dueño.
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Amistades
    match /friendships/{friendshipId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.requesterId
                      || request.auth.uid == resource.data.addresseeId);

      allow create: if request.auth != null
                    && request.resource.data.requesterId == request.auth.uid
                    && request.resource.data.addresseeId != request.auth.uid
                    && request.resource.data.status == 'pending';

      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.requesterId
                        || request.auth.uid == resource.data.addresseeId)
                    && request.resource.data.status in ['pending', 'accepted'];
    }

    // Grupos
    match /groups/{groupId} {
      function isMember() {
        return request.auth != null && request.auth.uid in resource.data.memberIds;
      }

      allow read: if isMember();

      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid
                    && request.auth.uid in request.resource.data.memberIds
                    && request.auth.uid in request.resource.data.admins
                    && request.resource.data.name is string;

      allow update: if request.auth != null
                    && request.auth.uid in resource.data.admins;
    }

    // Gastos (colección raíz)
    match /expenses/{expenseId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.participantIds is list
                    && request.auth.uid in request.resource.data.participantIds
                    && request.resource.data.amount > 0
                    && request.resource.data.participantIds.size() > 0
                    && request.resource.data.splits.size() > 0
                    && request.resource.data.splitType in ['equal', 'custom'];

      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.createdBy;
    }

    // Actividad básica
    match /activityLogs/{activityId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
    }

    // Pagos manuales
    match /settlements/{settlementId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.fromUserId
                      || request.auth.uid == resource.data.toUserId);

      allow create: if request.auth != null
                    && request.resource.data.fromUserId == request.auth.uid
                    && request.resource.data.toUserId != request.auth.uid
                    && request.resource.data.amount > 0;

      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.fromUserId;
    }

    // Bloqueo por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
