rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isGroupMember(groupId) {
      return signedIn()
             && exists(/databases/$(database)/documents/groups/$(groupId))
             && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    /* USERS */
    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isUser(userId);

      match /notificationTokens/{tokenId} {
        function validNotificationToken() {
          return request.resource.data.token is string
                 && request.resource.data.token.size() > 0
                 && request.resource.data.platform == 'web'
                 && request.resource.data.userAgent is string;
        }

        allow read, delete: if isUser(userId);
        allow create, update: if isUser(userId) && validNotificationToken();
      }
    }

    /* FRIENDSHIPS */
    match /friendships/{friendshipId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.requesterId
          || request.auth.uid == resource.data.addresseeId);

      allow create: if signedIn()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.addresseeId != request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if signedIn()
        && (request.auth.uid == resource.data.requesterId
          || request.auth.uid == resource.data.addresseeId)
        && request.resource.data.status in ['pending', 'accepted'];

      allow delete: if signedIn()
        && (request.auth.uid == resource.data.requesterId
          || request.auth.uid == resource.data.addresseeId);
    }

    /* GROUPS */
    match /groups/{groupId} {
      function isMember() {
        return signedIn() && request.auth.uid in resource.data.memberIds;
      }

      allow read: if isMember();

      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && request.auth.uid in request.resource.data.admins
        && request.resource.data.name is string;

      allow update: if signedIn() && request.auth.uid in resource.data.admins;
    }

    /* EXPENSES */
    match /expenses/{expenseId} {
      function amountPositive() {
        return request.resource.data.amount is number
               && request.resource.data.amount > 0;
      }

      function participantsValid() {
        return request.resource.data.participantIds is list
               && request.resource.data.participantIds.size() > 0
               && request.resource.data.paidBy is string
               && request.resource.data.paidBy in request.resource.data.participantIds
               && request.auth.uid in request.resource.data.participantIds;
      }

      function splitsPresent() {
        return request.resource.data.splits is list
               && request.resource.data.splits.size() > 0;
      }

      allow read: if signedIn()
        && (
          request.auth.uid in resource.data.participantIds
          || (resource.data.groupId is string && isGroupMember(resource.data.groupId))
        );

      allow create: if signedIn()
        && participantsValid()
        && amountPositive()
        && splitsPresent()
        && (
          !(request.resource.data.groupId is string)
          || isGroupMember(request.resource.data.groupId)
        );

      allow update, delete: if signedIn() && request.auth.uid == resource.data.createdBy;
    }

    /* ACTIVITY LOGS */
    match /activityLogs/{activityId} {
      allow read, create: if signedIn();
    }

    /* SETTLEMENTS */
    match /settlements/{settlementId} {
      function amountPositive() {
        return request.resource.data.amount is number
               && request.resource.data.amount > 0;
      }

      function partiesValid() {
        return request.resource.data.fromUserId is string
               && request.resource.data.toUserId is string
               && request.resource.data.fromUserId != request.resource.data.toUserId
               && request.resource.data.fromUserId == request.auth.uid;
      }

      allow read: if signedIn()
        && (
          request.auth.uid == resource.data.fromUserId
          || request.auth.uid == resource.data.toUserId
        );

      allow create: if signedIn()
        && amountPositive()
        && partiesValid();

      allow update, delete: if signedIn() && request.auth.uid == resource.data.fromUserId;
    }

    /* DEFAULT DENY */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
